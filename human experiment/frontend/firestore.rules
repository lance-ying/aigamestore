rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Gameplay sessions collection
    match /gameplay_sessions/{sessionId} {
      // Anyone can read sessions (for analytics and research)
      allow read: if true;

      // Only create if authenticated (implement auth later)
      // For now, allow all writes for development
      allow create: if true;

      // Only update own sessions (implement proper auth later)
      allow update: if true;

      // Only allow deletion via Admin SDK
      allow delete: if false;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read user stats
      allow read: if true;

      // Only authenticated users can write (implement auth later)
      allow write: if true;
    }

    // Games collection
    match /games/{gameId} {
      // Anyone can read game info
      allow read: if true;

      // Only admins can write (via Admin SDK only)
      allow write: if false;
    }
  }
}
