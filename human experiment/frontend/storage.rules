rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Game files - public read only
    match /games/{gameId}/game_files/{allPaths=**} {
      // Anyone can read game assets
      allow read: if true;

      // Only admins can write (via Admin SDK only)
      allow write: if false;
    }

    // User session files - public read, authenticated write
    // Match nested game paths like games_pilot/method/game_XXXX/sample_0
    match /games/{gameId=**}/user_sessions/{userId}/{sessionId}/{fileName} {
      // Anyone can read (for analytics/research)
      allow read: if true;

      // Allow writes with file type and size validation
      // For now, allow all writes during development
      // TODO: Add authentication check: request.auth != null && request.auth.uid == userId
      allow write: if (
        (fileName == 'video.webm' && request.resource.size < 50 * 1024 * 1024) || // 50MB max for video
        (fileName == 'inputs.json' && request.resource.size < 1 * 1024 * 1024) || // 1MB max for inputs
        (fileName == 'scores.json' && request.resource.size < 1 * 1024 * 1024) || // 1MB max for scores
        (fileName == 'metadata.json' && request.resource.size < 100 * 1024) || // 100KB max for metadata
        (fileName == 'logs.json' && request.resource.size < 5 * 1024 * 1024) || // 5MB max for logs
        (fileName == 'ratings.json' && request.resource.size < 10 * 1024) // 10KB max for ratings
      );
    }

    // End-of-study feedback - public read, anyone can write
    match /end_study_feedback/{userId}/{fileName} {
      // Anyone can read (for analytics/research)
      allow read: if true;

      // Allow writes with file type and size validation
      allow write: if (
        fileName == 'feedback.json' && request.resource.size < 100 * 1024 // 100KB max for feedback
      );
    }

    // Game feedback - public read, anyone can write
    // Match nested paths like game_feedback/{userId}/{sessionId}/{gameId}/feedback.json
    match /game_feedback/{userId}/{sessionId}/{gameId=**}/feedback.json {
      // Anyone can read (for analytics/research)
      allow read: if true;

      // Allow writes with file type and size validation
      allow write: if request.resource.size < 100 * 1024; // 100KB max for feedback
    }
  }
}
