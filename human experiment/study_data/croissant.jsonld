  "@type": "sc:Dataset",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "name": "AI GameStore Study Data",
  "description": "Gameplay sessions, per-session input/score telemetry, and qualitative feedback collected from a deployed user study of 128 Prolific participants playing 100 LLM-generated HTML5 browser games (3,722 total sessions). Companion to the AI GameStore NeurIPS 2026 E&D submission.",
  "version": "1.0.0",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://github.com/[anonymized]/aigamestore",
  "citeAs": "Anonymous Authors. AI GameStore: An LLM-Generated Browser Game Corpus and User-Study Dataset. NeurIPS 2026 (under review).",
  "creator": {
    "@type": "Organization",
    "name": "Anonymous"
  },
  "keywords": [
    "human-computer interaction",
    "user study",
    "LLM-generated games",
    "gameplay telemetry",
    "browser games"
  ],
  "isLiveDataset": false,
  "rai:dataCollection": "Participants were recruited through Prolific and played a sequence of LLM-generated HTML5 games in a browser-based study. Per-session input event streams, score time-series, and metadata were captured client-side via the participant frontend (see ../frontend/) and persisted to Firebase Firestore + Storage. Per-game feedback was collected immediately after each game; an end-of-study survey collected demographics and free-text feedback.",
  "rai:dataCollectionType": [
    "Crowdsourced",
    "User study"
  ],
  "rai:dataAnnotationProtocol": "Self-reported by participants via in-app forms (per-game ratings; end-of-study free-text and demographic categorical fields). No external annotators.",
  "rai:dataPreprocessingProtocol": [
    "Pre-launch test sessions from research-team accounts (non-Prolific-format user IDs) were removed.",
    "Verbose runtime debug logs (~189 MB) were excluded.",
    "Firebase Storage URLs in session records were nulled out; corresponding files are bundled in this release.",
    "Gameplay videos (~3.2 GB) are released as a sibling dataset (see distribution: aigamestore-videos)."
  ],
  "rai:personalSensitiveInformation": "Participant identifiers are Prolific IDs (24-character hex). Prolific IDs are pseudonymous: they are stable within the Prolific platform but cannot be linked to real-world identities without Prolific's cooperation. Self-reported demographic fields (age band, gender, gaming frequency, gaming experience) are released with participant consent. No direct identifiers (names, emails, IP addresses) are present; the deviceInfo.ip field is null in all records.",
  "rai:dataReleaseMaintenancePlan": "Static research artifact. Errata and corrections, if any, will be published alongside the dataset.",
  "rai:dataUseCases": [
    "Quantitative analysis of human gameplay behavior on LLM-generated games",
    "Modeling player engagement, score progression, and game completion",
    "Reference for LLM game-generation and game-playability evaluation"
  ],
  "rai:dataLimitations": [
    "Participants are sampled from Prolific and skew toward English-speaking, gaming-experienced adults.",
    "Game corpus is fixed at the 100 games shipped in the companion frontend; no live regeneration.",
    "Score semantics are game-specific; cross-game score comparisons are not meaningful without per-game normalization.",
    "Feedback is self-report and subject to standard self-report biases."
  ],
  "rai:dataSocialImpact": "Intended for HCI and ML research on LLM-generated interactive content. Demographic distributions reflect Prolific's pool composition, not the general population.",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "users-json",
      "name": "users.json",
      "description": "Array of 128 participant records.",
      "contentUrl": "firestore/users.json",
      "encodingFormat": "application/json",
      "sha256": "54987cfe925b3dd682a49dc3aecb866ade6946772a0077bdb5fb84196bb60b58"
    },
    {
      "@type": "cr:FileObject",
      "@id": "gameplay-sessions-json",
      "name": "gameplay_sessions.json",
      "description": "Array of 3,722 session records (one per game played by a participant).",
      "contentUrl": "firestore/gameplay_sessions.json",
      "encodingFormat": "application/json",
      "sha256": "3cd36a5ed764bd493fce687286da25cfee8136f69b0e26b02d7d2a87fa2f62c1"
    },
    {
      "@type": "cr:FileSet",
      "@id": "session-inputs-files",
      "name": "session-inputs",
      "description": "Per-session input event streams (mouse + keyboard).",
      "encodingFormat": "application/json",
      "includes": "sessions/*/user_sessions/*/*/inputs.json"
    },
    {
      "@type": "cr:FileSet",
      "@id": "session-scores-files",
      "name": "session-scores",
      "description": "Per-session score time-series and final score.",
      "encodingFormat": "application/json",
      "includes": "sessions/*/user_sessions/*/*/scores.json"
    },
    {
      "@type": "cr:FileSet",
      "@id": "session-metadata-files",
      "name": "session-metadata",
      "description": "Per-session metadata (game ID, user ID, start/end time, fps, device info).",
      "encodingFormat": "application/json",
      "includes": "sessions/*/user_sessions/*/*/metadata.json"
    },
    {
      "@type": "cr:FileSet",
      "@id": "per-game-feedback-files",
      "name": "per-game-feedback",
      "description": "Per-game feedback submitted by participants immediately after each game (~700 files).",
      "encodingFormat": "application/json",
      "includes": "feedback/per_game/**/feedback.json"
    },
    {
      "@type": "cr:FileSet",
      "@id": "end-study-feedback-files",
      "name": "end-study-feedback",
      "description": "End-of-study survey responses including demographics and free-text feedback (~70 files).",
      "encodingFormat": "application/json",
      "includes": "feedback/end_study/*/feedback.json"
    },
    {
      "@type": "cr:FileObject",
      "@id": "aigamestore-videos",
      "name": "aigamestore-videos",
      "description": "Companion video archive: per-session screen recordings (~3.2 GB across 902 sessions). Directory layout mirrors sessions/ in this dataset; videos can be aligned by path. Released separately due to size.",
      "contentUrl": "PLACEHOLDER_VIDEO_ARCHIVE_URL",
      "encodingFormat": "application/zip"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "users",
      "name": "users",
      "description": "Participant records. One per Prolific participant.",
      "key": { "@id": "users/userId" },
      "field": [
        {
          "@type": "cr:Field",
          "@id": "users/id",
          "name": "id",
          "description": "Same value as userId.",
          "dataType": "sc:Text",
          "source": { "fileObject": { "@id": "users-json" }, "extract": { "jsonPath": "$[*].id" } }
        },
        {
          "@type": "cr:Field",
          "@id": "users/userId",
          "name": "userId",
          "description": "Prolific participant ID (24-character hex). Pseudonymous.",
          "dataType": "sc:Text",
          "source": { "fileObject": { "@id": "users-json" }, "extract": { "jsonPath": "$[*].userId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "users/totalSessions",
          "name": "totalSessions",
          "description": "Number of sessions recorded for this participant in users.json (note: cross-check against gameplay_sessions.json for ground-truth count).",
          "dataType": "sc:Integer",
          "source": { "fileObject": { "@id": "users-json" }, "extract": { "jsonPath": "$[*].totalSessions" } }
        },
        {
          "@type": "cr:Field",
          "@id": "users/gamesPlayed",
          "name": "gamesPlayed",
          "description": "List of game IDs (`all_92_games/<slug>`) the participant played.",
          "dataType": "sc:Text",
          "repeated": true,
          "source": { "fileObject": { "@id": "users-json" }, "extract": { "jsonPath": "$[*].gamesPlayed[*]" } }
        },
        {
          "@type": "cr:Field",
          "@id": "users/createdAt_seconds",
          "name": "createdAt_seconds",
          "description": "Account creation Unix timestamp (seconds).",
          "dataType": "sc:Integer",
          "source": { "fileObject": { "@id": "users-json" }, "extract": { "jsonPath": "$[*].createdAt._seconds" } }
        },
        {
          "@type": "cr:Field",
          "@id": "users/lastActiveAt_seconds",
          "name": "lastActiveAt_seconds",
          "description": "Last active Unix timestamp (seconds).",
          "dataType": "sc:Integer",
          "source": { "fileObject": { "@id": "users-json" }, "extract": { "jsonPath": "$[*].lastActiveAt._seconds" } }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "gameplay_sessions",
      "name": "gameplay_sessions",
      "description": "One record per game played. 3,722 records total.",
      "key": { "@id": "gameplay_sessions/sessionId" },
      "field": [
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/sessionId",
          "name": "sessionId",
          "description": "`session_<timestamp>_<rand>`.",
          "dataType": "sc:Text",
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].sessionId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/userId",
          "name": "userId",
          "description": "Prolific participant ID. Foreign key to users.userId.",
          "dataType": "sc:Text",
          "references": { "@id": "users/userId" },
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].userId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/gameId",
          "name": "gameId",
          "description": "`all_92_games/<slug>`. Strip the `all_92_games/` prefix to align with sessions/ directory layout.",
          "dataType": "sc:Text",
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].gameId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/duration",
          "name": "duration",
          "description": "Session duration in seconds.",
          "dataType": "sc:Integer",
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].duration" } }
        },
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/completed",
          "name": "completed",
          "description": "Whether gameplay reached a clean end state.",
          "dataType": "sc:Boolean",
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].completed" } }
        },
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/score",
          "name": "score",
          "description": "Game-specific final score. Not comparable across games without per-game normalization.",
          "dataType": "sc:Integer",
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].score" } }
        },
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/timestamp_seconds",
          "name": "timestamp_seconds",
          "description": "Session timestamp Unix seconds.",
          "dataType": "sc:Integer",
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].timestamp._seconds" } }
        },
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/deviceInfo_platform",
          "name": "deviceInfo_platform",
          "description": "Reported OS platform string (e.g. `Win32`, `MacIntel`).",
          "dataType": "sc:Text",
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].deviceInfo.platform" } }
        },
        {
          "@type": "cr:Field",
          "@id": "gameplay_sessions/deviceInfo_timezone",
          "name": "deviceInfo_timezone",
          "description": "Browser-reported IANA timezone.",
          "dataType": "sc:Text",
          "source": { "fileObject": { "@id": "gameplay-sessions-json" }, "extract": { "jsonPath": "$[*].deviceInfo.timezone" } }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "session_inputs",
      "name": "session_inputs",
      "description": "Time-stamped input events per session (mouse + keyboard).",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "session_inputs/timestamp",
          "name": "timestamp",
          "description": "Unix milliseconds.",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-inputs-files" }, "extract": { "jsonPath": "$.events[*].timestamp" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_inputs/type",
          "name": "type",
          "description": "Event type: `mousemove`, `mousedown`, `mouseup`, `keydown`, `keyup`, etc.",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "session-inputs-files" }, "extract": { "jsonPath": "$.events[*].type" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_inputs/key",
          "name": "key",
          "description": "Key name for keyboard events; null otherwise.",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "session-inputs-files" }, "extract": { "jsonPath": "$.events[*].key" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_inputs/x",
          "name": "x",
          "description": "Mouse x coordinate; null for non-mouse events.",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-inputs-files" }, "extract": { "jsonPath": "$.events[*].x" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_inputs/y",
          "name": "y",
          "description": "Mouse y coordinate; null for non-mouse events.",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-inputs-files" }, "extract": { "jsonPath": "$.events[*].y" } }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "session_scores",
      "name": "session_scores",
      "description": "Per-frame score samples per session.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "session_scores/frame",
          "name": "frame",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-scores-files" }, "extract": { "jsonPath": "$.scoreTimeSeries[*].frame" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_scores/timestamp",
          "name": "timestamp",
          "description": "Unix milliseconds.",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-scores-files" }, "extract": { "jsonPath": "$.scoreTimeSeries[*].timestamp" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_scores/score",
          "name": "score",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-scores-files" }, "extract": { "jsonPath": "$.scoreTimeSeries[*].score" } }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "session_metadata",
      "name": "session_metadata",
      "description": "Per-session metadata: gameId, userId, timing, video frame info, device info.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "session_metadata/sessionId",
          "name": "sessionId",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.sessionId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_metadata/gameId",
          "name": "gameId",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.gameId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_metadata/userId",
          "name": "userId",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.userId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_metadata/startTime",
          "name": "startTime",
          "description": "ISO-8601 UTC.",
          "dataType": "sc:Date",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.startTime" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_metadata/endTime",
          "name": "endTime",
          "description": "ISO-8601 UTC.",
          "dataType": "sc:Date",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.endTime" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_metadata/duration",
          "name": "duration",
          "description": "Seconds.",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.duration" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_metadata/fps",
          "name": "fps",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.fps" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_metadata/videoWidth",
          "name": "videoWidth",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.videoWidth" } }
        },
        {
          "@type": "cr:Field",
          "@id": "session_metadata/videoHeight",
          "name": "videoHeight",
          "dataType": "sc:Integer",
          "source": { "fileSet": { "@id": "session-metadata-files" }, "extract": { "jsonPath": "$.videoHeight" } }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "end_study_feedback",
      "name": "end_study_feedback",
      "description": "End-of-study survey responses with demographics. ~70 records.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/prolificId",
          "name": "prolificId",
          "description": "Prolific participant ID. Foreign key to users.userId.",
          "dataType": "sc:Text",
          "references": { "@id": "users/userId" },
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.prolificId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/technicalIssues",
          "name": "technicalIssues",
          "description": "Free text. Did the participant report technical issues?",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.feedback.technicalIssues" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/confusingParts",
          "name": "confusingParts",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.feedback.confusingParts" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/suggestions",
          "name": "suggestions",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.feedback.suggestions" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/funCriteria",
          "name": "funCriteria",
          "description": "Free text. What does the participant consider 'fun'?",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.feedback.funCriteria" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/age",
          "name": "age",
          "description": "Age band (e.g. `18-24`, `25-34`, `35-44`, `45-54`, `55-64`, `65+`).",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.demographics.age" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/gender",
          "name": "gender",
          "description": "Self-reported gender.",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.demographics.gender" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/gamingFrequency",
          "name": "gamingFrequency",
          "description": "Self-reported play frequency (e.g. `Daily`, `Weekly`, `Monthly`, `Rarely`, `Never`).",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.demographics.gamingFrequency" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/gamingExperience",
          "name": "gamingExperience",
          "description": "Self-reported experience level.",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.demographics.gamingExperience" } }
        },
        {
          "@type": "cr:Field",
          "@id": "end_study_feedback/submittedAt",
          "name": "submittedAt",
          "description": "ISO-8601 UTC.",
          "dataType": "sc:Date",
          "source": { "fileSet": { "@id": "end-study-feedback-files" }, "extract": { "jsonPath": "$.submittedAt" } }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "per_game_feedback",
      "name": "per_game_feedback",
      "description": "Per-game feedback submitted immediately after each game. ~700 records. Some fields are sparse depending on the deployed form version.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "per_game_feedback/sessionId",
          "name": "sessionId",
          "description": "Session this feedback corresponds to. Foreign key to gameplay_sessions.sessionId.",
          "dataType": "sc:Text",
          "references": { "@id": "gameplay_sessions/sessionId" },
          "source": { "fileSet": { "@id": "per-game-feedback-files" }, "extract": { "jsonPath": "$.sessionId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "per_game_feedback/gameId",
          "name": "gameId",
          "dataType": "sc:Text",
          "source": { "fileSet": { "@id": "per-game-feedback-files" }, "extract": { "jsonPath": "$.gameId" } }
        },
        {
          "@type": "cr:Field",
          "@id": "per_game_feedback/userId",
          "name": "userId",
          "description": "Prolific participant ID. Foreign key to users.userId.",
