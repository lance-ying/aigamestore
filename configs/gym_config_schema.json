{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gym API Configuration Schema",
  "description": "Configuration schema for p5.js game Gym API wrappers",
  "type": "object",
  "required": ["game_name", "action_space", "observation_space"],
  "properties": {
    "game_name": {
      "type": "string",
      "description": "Name of the game"
    },
    "action_space": {
      "type": "object",
      "description": "OpenAI Gym action space definition",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Discrete", "Box", "MultiDiscrete", "MultiBinary"],
          "description": "Type of action space"
        },
        "n": {
          "type": "integer",
          "description": "Number of discrete actions (for Discrete type)",
          "minimum": 1
        },
        "shape": {
          "type": "array",
          "items": {"type": "integer"},
          "description": "Shape of continuous action space (for Box type)"
        },
        "low": {
          "type": "number",
          "description": "Lower bound for Box action space"
        },
        "high": {
          "type": "number",
          "description": "Upper bound for Box action space"
        },
        "labels": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Human-readable labels for each action"
        }
      }
    },
    "observation_space": {
      "type": "object",
      "description": "OpenAI Gym observation space definition",
      "required": ["type", "shape"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Box", "Discrete", "Dict"],
          "description": "Type of observation space"
        },
        "shape": {
          "type": "array",
          "items": {"type": "integer"},
          "description": "Shape of the observation (e.g., [18] for 18-dim vector)"
        },
        "dtype": {
          "type": "string",
          "enum": ["float32", "float64", "int32", "uint8"],
          "default": "float32",
          "description": "Data type of observations"
        },
        "low": {
          "type": "number",
          "description": "Lower bound for values (default: -inf)"
        },
        "high": {
          "type": "number",
          "description": "Upper bound for values (default: +inf)"
        }
      }
    },
    "observation_fields": {
      "type": "array",
      "description": "Ordered list of observation field descriptors",
      "items": {
        "type": "object",
        "required": ["name", "type", "size"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Field name (e.g., 'player', 'nearestEnemy')"
          },
          "type": {
            "type": "string",
            "description": "Field type (e.g., 'player_state', 'entity', 'scalar')"
          },
          "size": {
            "type": "integer",
            "description": "Number of values this field contributes",
            "minimum": 1
          },
          "fields": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Sub-field names (e.g., ['x', 'y', 'angle', 'length', 'speed', 'isBoosting'])"
          }
        }
      }
    },
    "control_mapping": {
      "type": "object",
      "description": "Mapping from action indices to game controls",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "keys": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Keyboard keys that trigger this action"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the action"
          }
        }
      }
    },
    "entity_types": {
      "type": "object",
      "description": "Types of entities in the game",
      "properties": {
        "player": {
          "type": "string",
          "description": "Player entity identifier"
        },
        "collectibles": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Types of collectible entities (e.g., ['pellets', 'massDrops'])"
        },
        "enemies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Types of enemy entities (e.g., ['aiSnakes'])"
        },
        "obstacles": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Types of obstacle entities"
        }
      }
    },
    "reward_components": {
      "type": "array",
      "description": "Components of the reward function (optional, for documentation)",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "weight": {"type": "number"},
          "description": {"type": "string"}
        }
      }
    },
    "canvas_size": {
      "type": "object",
      "description": "Game canvas dimensions",
      "properties": {
        "width": {"type": "integer"},
        "height": {"type": "integer"}
      }
    },
    "max_episode_steps": {
      "type": "integer",
      "description": "Maximum steps per episode",
      "default": 10000,
      "minimum": 1
    }
  }
}










